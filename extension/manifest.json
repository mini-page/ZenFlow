{
  "manifest_version": 3,
  "name": "Zen Flow - Focus & Wellness Companion",
  "version": "1.0.0",
  "description": "A quick-access companion for focus timers, hydration tracking, and mindful breaks in your side panel.",
  "permissions": ["sidePanel", "storage"],
  "action": {
    "default_title": "Open Zen Flow Side Panel"
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  }
}
